# Application
APP_NAME=rag-pipeline-demo
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# LLM (Ollama local)
LLM__PROVIDER=ollama
LLM__MODEL=mistral:7b-instruct
LLM__BASE_URL=http://ollama:11434
LLM__TEMPERATURE=0.0

# Embedding (Ollama local)
EMBEDDING__PROVIDER=ollama
EMBEDDING__MODEL=nomic-embed-text
EMBEDDING__BASE_URL=http://ollama:11434

# Vector Store
VECTORSTORE__PROVIDER=chroma        # chroma (dev) | pgvector (prod)
VECTORSTORE__PERSIST_DIR=.chroma

# Database (pgvector — prod)
DB__HOST=postgres
DB__PORT=5432
DB__NAME=ragdb
DB__USER=postgres
DB__PASSWORD=changeme

# Redis
REDIS__HOST=redis
REDIS__PORT=6379
REDIS__PASSWORD=

# API
API__SECRET_KEY=change-me-in-production-use-a-long-random-string
API__JWT_EXPIRE_MINUTES=60
API__RATE_LIMIT_PER_MINUTE=60

# Monitoring — LangFuse
MONITORING__LANGFUSE_ENABLED=false
MONITORING__LANGFUSE_HOST=http://langfuse:3000
MONITORING__LANGFUSE_PUBLIC_KEY=
MONITORING__LANGFUSE_SECRET_KEY=

# AWS (prod uniquement)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
